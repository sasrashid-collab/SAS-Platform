      "id": "prod-1782956875021",
      "name": "ئەربەئیلۆ",
      "description": "سیستەمی پێشکەوتووی بەڕێوەبردنی فرۆشگا و کۆگای فەرشی ئێرانی ئەربەئیلۆ، بۆ ڕێکخستنی فاتورە، چاودێری کۆگا و شیکردنەوەی دارایی بە شێوازێکی مۆدێرن و ئاسان.",
      "type": "app",
      "html": "<!DOCTYPE html><html lang=\"ku\" dir=\"rtl\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>سیستەمی ئەربەئیلۆ</title><script src=\"https://cdn.tailwindcss.com\"></script><link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\" rel=\"stylesheet\"><script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script><link href=\"https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;700&display=swap\" rel=\"stylesheet\"><style>body { font-family: 'Vazirmatn', sans-serif; }</style></head><body class=\"bg-stone-50 text-stone-800 min-h-screen flex flex-col\"><header class=\"bg-amber-950 text-amber-100 border-b border-amber-800 shadow-lg\"><div class=\"container mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center\"><div class=\"flex items-center space-x-3 space-x-reverse\"><div class=\"bg-amber-600 p-2.5 rounded-lg text-white shadow-inner\"><i class=\"fa-solid fa-gem text-2xl\"></i></div><div><h1 class=\"text-2xl font-bold tracking-wide text-amber-100\">ئەربەئیلۆ <span class=\"text-xs text-amber-400 font-normal\">Arbailo</span></h1><p class=\"text-xs text-amber-300\">سیستەمی بەڕێوەبردنی فەرشی ئێرانی شاهانە</p></div></div><nav class=\"flex space-x-1 space-x-reverse mt-4 md:mt-0 bg-amber-900/50 p-1.5 rounded-xl border border-amber-800\"><button onclick=\"switchTab('dashboard')\" id=\"tab-dashboard\" class=\"tab-btn active px-4 py-2 rounded-lg text-sm font-medium transition-all bg-amber-600 text-white shadow-md\"><i class=\"fa-solid fa-chart-pie ml-2\"></i>پێشاندەر</button><button onclick=\"switchTab('inventory')\" id=\"tab-inventory\" class=\"tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all text-amber-200 hover:bg-amber-800/50\"><i class=\"fa-solid fa-warehouse ml-2\"></i>کۆگا</button><button onclick=\"switchTab('invoices')\" id=\"tab-invoices\" class=\"tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all text-amber-200 hover:bg-amber-800/50\"><i class=\"fa-solid fa-file-invoice-dollar ml-2\"></i>فاتورەکان</button><button onclick=\"switchTab('finances')\" id=\"tab-finances\" class=\"tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all text-amber-200 hover:bg-amber-800/50\"><i class=\"fa-solid fa-wallet ml-2\"></i>دارایی</button></nav></div></header><main class=\"flex-grow container mx-auto px-4 py-8\"><section id=\"dashboard-section\" class=\"tab-content block\"><div class=\"grid grid-cols-1 md:grid-cols-4 gap-6 mb-8\"><div class=\"bg-white p-6 rounded-2xl border border-stone-200 shadow-sm flex items-center justify-between\"><div class=\"space-y-1\"><p class=\"text-sm text-stone-500 font-medium\">کۆی فەرش لە کۆگا</p><h3 id=\"widget-total-carpets\" class=\"text-3xl font-bold text-amber-950\">0</h3></div><div class=\"bg-amber-100 p-4 rounded-xl text-amber-700\"><i class=\"fa-solid fa-layer-group text-2xl\"></i></div></div><div class=\"bg-white p-6 rounded-2xl border border-stone-200 shadow-sm flex items-center justify-between\"><div class=\"space-y-1\"><p class=\"text-sm text-stone-500 font-medium\">فاتورە فرۆشراوەکان</p><h3 id=\"widget-total-sales-count\" class=\"text-3xl font-bold text-emerald-700\">0</h3></div><div class=\"bg-emerald-50 p-4 rounded-xl text-emerald-700\"><i class=\"fa-solid fa-circle-check text-2xl\"></i></div></div><div class=\"bg-white p-6 rounded-2xl border border-stone-200 shadow-sm flex items-center justify-between\"><div class=\"space-y-1\"><p class=\"text-sm text-stone-500 font-medium\">کۆی داهاتی فرۆش</p><h3 id=\"widget-total-revenue\" class=\"text-2xl font-bold text-amber-950\">$0</h3></div><div class=\"bg-amber-50 p-4 rounded-xl text-amber-800\"><i class=\"fa-solid fa-coins text-2xl\"></i></div></div><div class=\"bg-white p-6 rounded-2xl border border-stone-200 shadow-sm flex items-center justify-between\"><div class=\"space-y-1\"><p class=\"text-sm text-stone-500 font-medium\">کۆی قازانجی گشتی</p><h3 id=\"widget-net-profit\" class=\"text-2xl font-bold text-emerald-600\">$0</h3></div><div class=\"bg-emerald-50 p-4 rounded-xl text-emerald-600\"><i class=\"fa-solid fa-chart-line-up text-2xl\"></i></div></div></div><div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8\"><div class=\"lg:col-span-2 bg-white p-6 rounded-2xl border border-stone-200 shadow-sm\"><div class=\"flex justify-between items-center mb-6\"><h3 class=\"text-lg font-bold text-stone-800\"><i class=\"fa-solid fa-arrow-trend-up ml-2 text-amber-600\"></i>جوڵەی فرۆشتنی مانگانە</h3><span class=\"text-xs text-stone-400\">نوێکراوەتەوە ئێستا</span></div><div class=\"relative h-64\"><canvas id=\"revenueChart\"></canvas></div></div><div class=\"bg-white p-6 rounded-2xl border border-stone-200 shadow-sm flex flex-col justify-between\"><h3 class=\"text-lg font-bold text-stone-800 mb-4\"><i class=\"fa-solid fa-bolt ml-2 text-amber-600\"></i>کردارە خێراکان</h3><div class=\"space-y-3 flex-grow flex flex-col justify-center\"><button onclick=\"openAddCarpetModal()\" class=\"w-full bg-amber-800 hover:bg-amber-900 text-white py-3 px-4 rounded-xl font-bold shadow transition flex items-center justify-center\"><i class=\"fa-solid fa-plus-circle ml-2\"></i>تۆمارکردنی فەرشی نوێ لە کۆگا</button><button onclick=\"openNewInvoiceModal()\" class=\"w-full bg-emerald-600 hover:bg-emerald-700 text-white py-3 px-4 rounded-xl font-bold shadow transition flex items-center justify-center\"><i class=\"fa-solid fa-receipt ml-2\"></i>دروستکردنی فاتورەی نوێ</button><button onclick=\"switchTab('finances')\" class=\"w-full bg-stone-100 hover:bg-stone-200 text-stone-800 py-3 px-4 rounded-xl font-bold transition flex items-center justify-center\"><i class=\"fa-solid fa-file-invoice-dollar ml-2\"></i>بینینی ڕاپۆرتی دارایی</button></div><div class=\"mt-4 p-3 bg-amber-50 border border-amber-200 rounded-xl text-xs text-amber-900 leading-relaxed\"><i class=\"fa-solid fa-circle-info ml-1\"></i> دەتوانیت بە ئاسانی کاڵاکان زیاد بکەیت و لە بەشی فاتورەکان فرۆشتن ئەنجام بدەیت بۆ ئەوەی داتای دارایی ڕاستەوخۆ نوێ ببێتەوە.</div></div></div></section><section id=\"inventory-section\" class=\"tab-content hidden\"><div class=\"flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4\"><div class=\"space-y-1\"><h2 class=\"text-xl font-bold text-stone-800\"><i class=\"fa-solid fa-warehouse ml-2 text-amber-700\"></i>کۆگای فەرشەکان</h2><p class=\"text-sm text-stone-500\">لیستی سەرجەم فەرشە ئێرانییە بەردەستەکانی نێو کۆگا</p></div><button onclick=\"openAddCarpetModal()\" class=\"bg-amber-800 hover:bg-amber-900 text-white px-5 py-2.5 rounded-xl font-bold shadow transition flex items-center\"><i class=\"fa-solid fa-plus ml-2\"></i> زیادکردنی فەرش</button></div><div class=\"bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden\"><div class=\"p-4 bg-stone-50 border-b border-stone-200 flex flex-col sm:flex-row gap-4 justify-between items-center\"><div class=\"relative w-full sm:w-72\"><span class=\"absolute inset-y-0 right-0 flex items-center pr-3 text-stone-400\"><i class=\"fa-solid fa-magnifying-glass\"></i></span><input type=\"text\" id=\"search-carpet\" onkeyup=\"filterCarpets()\" placeholder=\"گەڕان بەپێی جۆر یان نەخش...\" class=\"w-full pr-10 pl-4 py-2 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-amber-500\"></div><div class=\"flex gap-2 w-full sm:w-auto\"><select id=\"filter-origin\" onchange=\"filterCarpets()\" class=\"w-full sm:w-40 border border-stone-200 rounded-xl text-sm px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-amber-500\"><option value=\"all\">سەرجەم سەرچاوەکان</option><option value=\"تەورێز\">تەورێز</option><option value=\"ئەسفەهان\">ئەسفەهان</option><option value=\"قوم\">قوم</option><option value=\"کاشان\">کاشان</option></select></div></div><div class=\"overflow-x-auto\"><table class=\"w-full text-right border-collapse\"><thead class=\"bg-stone-100 text-stone-600 text-xs uppercase border-b border-stone-200\"><tr class=\"divide-x divide-x-reverse divide-stone-200\"><th class=\"px-6 py-4\">کۆد</th><th class=\"px-6 py-4\">نەخش و جۆر</th><th class=\"px-6 py-4\">سەرچاوە</th><th class=\"px-6 py-4\">قەبارە (مەتر)</th><th class=\"px-6 py-4\">نرخی کڕین</th><th class=\"px-6 py-4\">نرخی فرۆشتن</th><th class=\"px-6 py-4\">ژمارەی بەردەست</th><th class=\"px-6 py-4 text-center\">کردارەکان</th></tr></thead><tbody id=\"carpet-table-body\" class=\"divide-y divide-stone-200 text-sm text-stone-700\"></tbody></table></div></div></section><section id=\"invoices-section\" class=\"tab-content hidden\"><div class=\"flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4\"><div class=\"space-y-1\"><h2 class=\"text-xl font-bold text-stone-800\"><i class=\"fa-solid fa-file-invoice-dollar ml-2 text-emerald-700\"></i>بەڕێوەبردنی فاتورەکان</h2><p class=\"text-sm text-stone-500\">تۆمارکردن، دروستکردن و بینینی فاتورەکانی فرۆشتنی فەرش</p></div><button onclick=\"openNewInvoiceModal()\" class=\"bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl font-bold shadow transition flex items-center\"><i class=\"fa-solid fa-file-invoice ml-2\"></i> فاتورەی نوێ</button></div><div class=\"bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden\"><div class=\"overflow-x-auto\"><table class=\"w-full text-right border-collapse\"><thead class=\"bg-stone-100 text-stone-600 text-xs uppercase border-b border-stone-200\"><tr class=\"divide-x divide-x-reverse divide-stone-200\"><th class=\"px-6 py-4\">ژمارەی فاتورە</th><th class=\"px-6 py-4\">کڕیار</th><th class=\"px-6 py-4\">بەروار</th><th class=\"px-6 py-4\">ناوی فەرش</th><th class=\"px-6 py-4\">دانە</th><th class=\"px-6 py-4\">کۆی گشتی</th><th class=\"px-6 py-4 text-center\">بینین / چاپ</th></tr></thead><tbody id=\"invoice-table-body\" class=\"divide-y divide-stone-200 text-sm text-stone-700\"></tbody></table></div></div></section><section id=\"finances-section\" class=\"tab-content hidden\"><div class=\"space-y-1 mb-6\"><h2 class=\"text-xl font-bold text-stone-800\"><i class=\"fa-solid fa-wallet ml-2 text-amber-700\"></i>راپۆرتی دارایی و ژمێریاری</h2><p class=\"text-sm text-stone-500\">شیکردنەوەی داهات، تێچوو و قازانج بە شێوازی ورد</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 mb-8\"><div class=\"bg-gradient-to-br from-emerald-800 to-emerald-950 p-6 rounded-2xl text-white shadow-md\"><p class=\"text-emerald-200 text-sm font-medium\">کۆی داهات (داهاتی گشتی)</p><h3 id=\"finance-total-revenue\" class=\"text-3xl font-bold mt-2\">$0</h3><div class=\"mt-4 text-xs text-emerald-300\"><i class=\"fa-solid fa-circle-arrow-up ml-1\"></i> لە فرۆشتنی فەرشەکانەوە بەدەستهاتووە</div></div><div class=\"bg-gradient-to-br from-red-800 to-red-950 p-6 rounded-2xl text-white shadow-md\"><p class=\"text-red-200 text-sm font-medium\">کۆی تێچوو (نرخی کڕین)</p><h3 id=\"finance-total-cost\" class=\"text-3xl font-bold mt-2\">$0</h3><div class=\"mt-4 text-xs text-red-300\"><i class=\"fa-solid fa-circle-arrow-down ml-1\"></i> بۆ کڕین و هێنانی فەرش خەرجکراوە</div></div><div class=\"bg-gradient-to-br from-amber-700 to-amber-900 p-6 rounded-2xl text-white shadow-md\"><p class=\"text-amber-200 text-sm font-medium\">سافی قازانج (Net Profit)</p><h3 id=\"finance-net-profit\" class=\"text-3xl font-bold mt-2\">$0</h3><div class=\"mt-4 text-xs text-amber-300\"><i class=\"fa-solid fa-wallet ml-1\"></i> قازانجی بەدەستهاتووی نەختینەیی</div></div></div><div class=\"bg-white p-6 rounded-2xl border border-stone-200 shadow-sm\"><h3 class=\"text-lg font-bold text-stone-800 mb-6\"><i class=\"fa-solid fa-list-check ml-2 text-amber-600\"></i>لیستی سەرجەم مامەڵە داراییەکان</h3><div class=\"overflow-x-auto\"><table class=\"w-full text-right border-collapse\"><thead class=\"bg-stone-50 text-stone-600 text-xs uppercase border-b border-stone-200\"><tr class=\"divide-x divide-x-reverse divide-stone-200\"><th class=\"px-6 py-4\">بەروار</th><th class=\"px-6 py-4\">جۆری چالاکی</th><th class=\"px-6 py-4\">وردەکاری</th><th class=\"px-6 py-4\">بڕی پارە</th><th class=\"px-6 py-4\">بارودۆخ</th></tr></thead><tbody id=\"finance-table-body\" class=\"divide-y divide-stone-200 text-sm text-stone-700\"></tbody></table></div></div></section></main><div id=\"add-carpet-modal\" class=\"fixed inset-0 bg-stone-900/60 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50\"><div class=\"bg-white rounded-2xl max-w-lg w-full overflow-hidden shadow-2xl border border-amber-900/10 transform transition-all\"><div class=\"bg-amber-950 text-white px-6 py-4 flex justify-between items-center\"><div><h3 class=\"text-lg font-bold\"><i class=\"fa-solid fa-plus-circle ml-2 text-amber-400\"></i>تۆمارکردنی فەرشی نوێ</h3><p class=\"text-xs text-amber-200\">تکایە سەرجەم خانەکان بە دروستی پڕبکەرەوە</p></div><button onclick=\"closeAddCarpetModal()\" class=\"text-amber-200 hover:text-white\"><i class=\"fa-solid fa-times text-xl\"></i></button></div><form id=\"add-carpet-form\" onsubmit=\"saveCarpet(event)\" class=\"p-6 space-y-4\"><div class=\"grid grid-cols-2 gap-4\"><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">ناوی فەرش / نەخش</label><input type=\"text\" id=\"carpet-name\" required class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-amber-600\" placeholder=\"نموونە: شا عەباسی\"></div><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">سەرچاوە (شار)</label><select id=\"carpet-origin\" class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-amber-600\"><option value=\"تەورێز\">تەورێز</option><option value=\"ئەسفەهان\">ئەسفەهان</option><option value=\"قوم\">قوم</option><option value=\"کاشان\">کاشان</option><option value=\"مەشھەد\">مەشھەد</option></select></div></div><div class=\"grid grid-cols-2 gap-4\"><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">قەبارە (مەتر دووجا)</label><input type=\"text\" id=\"carpet-size\" required class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-amber-600\" placeholder=\"نموونە: ٣ * ٤\"></div><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">ژمارەی بەردەست (کۆگا)</label><input type=\"number\" id=\"carpet-stock\" required min=\"1\" class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-amber-600\" placeholder=\"نموونە: ٥\"></div></div><div class=\"grid grid-cols-2 gap-4\"><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">نرخی کڕین (USD)</label><input type=\"number\" id=\"carpet-cost\" required min=\"1\" class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-amber-600\" placeholder=\"$1200\"></div><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">نرخی فرۆشتن (USD)</label><input type=\"number\" id=\"carpet-price\" required min=\"1\" class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-amber-600\" placeholder=\"$1800\"></div></div><div class=\"flex justify-end space-x-2 space-x-reverse pt-4 border-t border-stone-100\"><button type=\"button\" onclick=\"closeAddCarpetModal()\" class=\"px-4 py-2 bg-stone-100 hover:bg-stone-200 text-stone-700 rounded-xl text-sm font-medium\">پاشگەزبوونەوە</button><button type=\"submit\" class=\"px-5 py-2 bg-amber-800 hover:bg-amber-900 text-white rounded-xl text-sm font-bold shadow-md\">تۆمارکردن لە کۆگا</button></div></form></div></div><div id=\"invoice-modal\" class=\"fixed inset-0 bg-stone-900/60 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50\"><div class=\"bg-white rounded-2xl max-w-xl w-full overflow-hidden shadow-2xl border border-emerald-900/10 transform transition-all\"><div class=\"bg-emerald-950 text-white px-6 py-4 flex justify-between items-center\"><div><h3 class=\"text-lg font-bold\"><i class=\"fa-solid fa-file-invoice-dollar ml-2 text-emerald-400\"></i>دروستکردنی فاتورەی نوێ</h3><p class=\"text-xs text-emerald-200\">تکایە فەرشەکە و ناو و زانیاری کڕیار دیاری بکە</p></div><button onclick=\"closeNewInvoiceModal()\" class=\"text-emerald-200 hover:text-white\"><i class=\"fa-solid fa-times text-xl\"></i></button></div><form id=\"invoice-form\" onsubmit=\"saveInvoice(event)\" class=\"p-6 space-y-4\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\"><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">ناوی کڕیار</label><input type=\"text\" id=\"customer-name\" required class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-600\" placeholder=\"ناوی تەواوی کڕیار\"></div><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">ژمارەی مۆبایل</label><input type=\"text\" id=\"customer-phone\" required class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-600\" placeholder=\"ڕێژەی مۆبایل\"></div></div><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">هەڵبژاردنی فەرش لە کۆگا</label><select id=\"invoice-carpet-select\" onchange=\"updateInvoicePricing()\" class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-600\"></select></div><div class=\"grid grid-cols-3 gap-4\"><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">ژمارە (دانە)</label><input type=\"number\" id=\"invoice-qty\" required min=\"1\" value=\"1\" onchange=\"updateInvoicePricing()\" onkeyup=\"updateInvoicePricing()\" class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-600\"></div><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">داشکاندن ($)</label><input type=\"number\" id=\"invoice-discount\" min=\"0\" value=\"0\" onchange=\"updateInvoicePricing()\" onkeyup=\"updateInvoicePricing()\" class=\"w-full px-3 py-2 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-600\"></div><div><label class=\"block text-xs font-bold text-stone-600 mb-1.5\">کۆی گشتی یەک دانە</label><div id=\"invoice-single-price\" class=\"text-lg font-bold text-stone-800 mt-1.5\">$0</div></div></div><div class=\"bg-stone-50 p-4 rounded-xl border border-stone-200 flex justify-between items-center\"><div><span class=\"text-xs text-stone-500 block\">کۆی گشتی بۆ پارەدان</span><span id=\"invoice-total-display\" class=\"text-2xl font-black text-emerald-700\">$0</span></div><div class=\"text-left\"><span class=\"text-xs text-stone-400 block\">تێچووی کۆگا:</span><span id=\"invoice-cost-display\" class=\"text-xs text-stone-500 font-semibold\">$0</span></div></div><div class=\"flex justify-end space-x-2 space-x-reverse pt-4 border-t border-stone-100\"><button type=\"button\" onclick=\"closeNewInvoiceModal()\" class=\"px-4 py-2 bg-stone-100 hover:bg-stone-200 text-stone-700 rounded-xl text-sm font-medium\">پاشگەزبوونەوە</button><button type=\"submit\" class=\"px-5 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-sm font-bold shadow-md\">دروستکردن و خەزنکردن</button></div></form></div></div><div id=\"invoice-view-modal\" class=\"fixed inset-0 bg-stone-900/60 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50\"><div class=\"bg-white rounded-2xl max-w-lg w-full overflow-hidden shadow-2xl border border-stone-300 transform transition-all\"><div class=\"bg-stone-900 text-white px-6 py-4 flex justify-between items-center\"><h3 class=\"text-lg font-bold\"><i class=\"fa-solid fa-receipt ml-2 text-amber-400\"></i>بینینی فاتورە</h3><button onclick=\"closeInvoiceViewModal()\" class=\"text-stone-400 hover:text-white\"><i class=\"fa-solid fa-times text-xl\"></i></button></div><div class=\"p-6 space-y-6\" id=\"invoice-print-area\"><div class=\"text-center pb-4 border-b border-stone-200\"><h2 class=\"text-2xl font-black text-amber-950\">ئەربەئیلۆ</h2><p class=\"text-xs text-stone-500\">فرۆشگای فەرشی ئێرانی ناوازە</p><p class=\"text-xs text-stone-400 mt-1\">هەولێر، شەقامی بازنەیی مەلیک مەحمود</p></div><div class=\"grid grid-cols-2 gap-4 text-xs text-stone-600\"><div class=\"space-y-1\"><p><strong class=\"text-stone-800\">ژمارەی فاتورە:</strong> <span id=\"view-inv-id\"></span></p><p><strong class=\"text-stone-800\">بەروار:</strong> <span id=\"view-inv-date\"></span></p></div><div class=\"space-y-1 text-left\"><p dir=\"rtl\"><strong class=\"text-stone-800\">کڕیار:</strong> <span id=\"view-inv-customer\"></span></p><p dir=\"rtl\"><strong class=\"text-stone-800\">مۆبایل:</strong> <span id=\"view-inv-phone\"></span></p></div></div><table class=\"w-full text-right text-xs mt-4 border-collapse\"><thead class=\"bg-stone-100 border-b border-stone-200\"><tr><th class=\"p-2\">ناونیشانی کاڵا</th><th class=\"p-2\">دانە</th><th class=\"p-2\">نرخی تاک</th><th class=\"p-2\">کۆی گشتی</th></tr></thead><tbody><tr class=\"border-b border-stone-100\"><td class=\"p-2\" id=\"view-inv-carpet-title\">-</td><td class=\"p-2\" id=\"view-inv-qty\">-</td><td class=\"p-2\" id=\"view-inv-price\">-</td><td class=\"p-2\" id=\"view-inv-subtotal\">-</td></tr></tbody></table><div class=\"space-y-1.5 text-xs text-stone-700 flex flex-col items-end pt-4\"><p>داشکاندن: <span id=\"view-inv-discount\" class=\"font-bold\">$0</span></p><p class=\"text-base font-bold text-amber-950\">کۆی گشتی کۆتایی: <span id=\"view-inv-total\">$0</span></p></div><div class=\"text-center text-xs text-stone-400 border-t border-stone-100 pt-4 mt-4\"><p>سوپاس بۆ کڕینەکەتان لە فەرشی ئێرانی ئەربەئیلۆ</p><p class=\"mt-1\">کاڵای فرۆشراو ناگۆڕدرێتەوە تەنها لە ماوەی ٢٤ کاتژمێردا نەبێت</p></div></div><div class=\"bg-stone-50 px-6 py-4 flex justify-end space-x-2 space-x-reverse border-t border-stone-100\"><button onclick=\"closeInvoiceViewModal()\" class=\"px-4 py-2 bg-stone-200 hover:bg-stone-300 text-stone-700 rounded-xl text-sm font-medium\">داخستن</button><button onclick=\"window.print()\" class=\"px-5 py-2 bg-amber-950 hover:bg-amber-900 text-white rounded-xl text-sm font-bold shadow-md\"><i class=\"fa-solid fa-print ml-1.5\"></i>چاپکردن</button></div></div></div><footer class=\"bg-amber-950 text-amber-300 py-6 border-t border-amber-900 mt-12\"><div class=\"container mx-auto px-4 text-center space-y-2\"><p class=\"text-sm\">© ٢٠٢٥ ئەربەئیلۆ - سیستەمی زیرەکی کۆگا و دارایی فەرشی ئێرانی</p><p class=\"text-xs text-amber-400\">گەشەپێدراوە بە شێوازی مۆدێرن و داینامیکی بۆ باشترین بەڕێوەبردن</p></div></footer><script>let carpets = [ { id: 'CRP-101', name: 'کاشانی کەهکەشان', origin: 'کاشان', size: '٣*٤', cost: 800, price: 1300, stock: 12 }, { id: 'CRP-102', name: 'تەورێزی نەخشی شاهانە', origin: 'تەورێز', size: '٢.٥*٣.٥', cost: 1500, price: 2400, stock: 6 }, { id: 'CRP-103', name: 'قوم ئاوریشمی گوڵزار', origin: 'قوم', size: '٢*٣', cost: 2200, price: 3500, stock: 4 }, { id: 'CRP-104', name: 'ئەسفەهانی مێهراب', origin: 'ئەسفەهان', size: '٣*٤', cost: 1200, price: 1950, stock: 8 } ]; let invoices = [ { id: 'INV-5001', customer: 'ئاراس ئەحمەد', phone: '07501234567', date: '2025-02-15', carpetId: 'CRP-101', carpetName: 'کاشانی کەهکەشان (کاشان)', qty: 2, price: 1300, discount: 100, total: 2500, cost: 1600 }, { id: 'INV-5002', customer: 'دیار عومەر', phone: '07709876543', date: '2025-02-18', carpetId: 'CRP-103', carpetName: 'قوم ئاوریشمی گوڵزار (قوم)', qty: 1, price: 3500, discount: 200, total: 3300, cost: 2200 } ]; let chartInstance = null; function switchTab(tabId) { document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden')); document.getElementById(tabId + '-section').classList.remove('hidden'); document.querySelectorAll('.tab-btn').forEach(btn => { btn.classList.remove('bg-amber-600', 'text-white', 'shadow-md'); btn.classList.add('text-amber-200', 'hover:bg-amber-800/50'); }); const activeBtn = document.getElementById('tab-' + tabId); activeBtn.classList.remove('text-amber-200', 'hover:bg-amber-800/50'); activeBtn.classList.add('bg-amber-600', 'text-white', 'shadow-md'); if(tabId === 'dashboard') { setTimeout(initChart, 100); } } function initApp() { renderCarpets(); renderInvoices(); populateCarpetSelect(); updateDashboardWidgets(); renderFinances(); initChart(); } function updateDashboardWidgets() { let totalStock = carpets.reduce((acc, curr) => acc + parseInt(curr.stock), 0); let totalSalesCount = invoices.reduce((acc, curr) => acc + parseInt(curr.qty), 0); let totalRevenue = invoices.reduce((acc, curr) => acc + curr.total, 0); let totalCost = invoices.reduce((acc, curr) => acc + (curr.cost * curr.qty), 0); let netProfit = totalRevenue - totalCost; document.getElementById('widget-total-carpets').innerText = totalStock; document.getElementById('widget-total-sales-count').innerText = totalSalesCount; document.getElementById('widget-total-revenue').innerText = '$' + totalRevenue.toLocaleString(); document.getElementById('widget-net-profit').innerText = '$' + netProfit.toLocaleString(); } function renderCarpets() { const tbody = document.getElementById('carpet-table-body'); tbody.innerHTML = ''; carpets.forEach(carpet => { const tr = document.createElement('tr'); tr.className = 'hover:bg-stone-50 transition divide-x divide-x-reverse divide-stone-100'; tr.innerHTML = ` <td class=\"px-6 py-4 font-bold text-amber-900\">${carpet.id}</td> <td class=\"px-6 py-4 font-medium\">${carpet.name}</td> <td class=\"px-6 py-4\">${carpet.origin}</td> <td class=\"px-6 py-4\">${carpet.size}</td> <td class=\"px-6 py-4 text-stone-500\">$${carpet.cost}</td> <td class=\"px-6 py-4 font-bold text-stone-800\">$${carpet.price}</td> <td class=\"px-6 py-4\"> <span class=\"px-2.5 py-1 rounded-full text-xs font-bold ${carpet.stock <= 3 ? 'bg-red-100 text-red-800' : 'bg-emerald-100 text-emerald-800'}\"> ${carpet.stock} دانە </span> </td> <td class=\"px-6 py-4 text-center\"> <button onclick=\"deleteCarpet('${carpet.id}')\" class=\"text-red-600 hover:text-red-950 transition-colors\"><i class=\"fa-regular fa-trash-can\"></i> سڕینەوە</button> </td> `; tbody.appendChild(tr); }); } function filterCarpets() { const searchQuery = document.getElementById('search-carpet').value.toLowerCase(); const originFilter = document.getElementById('filter-origin').value; const tbody = document.getElementById('carpet-table-body'); tbody.innerHTML = ''; carpets.filter(carpet => { const matchesSearch = carpet.name.toLowerCase().includes(searchQuery) || carpet.id.toLowerCase().includes(searchQuery); const matchesOrigin = originFilter === 'all' || carpet.origin === originFilter; return matchesSearch && matchesOrigin; }).forEach(carpet => { const tr = document.createElement('tr'); tr.className = 'hover:bg-stone-50 transition divide-x divide-x-reverse divide-stone-100'; tr.innerHTML = ` <td class=\"px-6 py-4 font-bold text-amber-900\">${carpet.id}</td> <td class=\"px-6 py-4 font-medium\">${carpet.name}</td> <td class=\"px-6 py-4\">${carpet.origin}</td> <td class=\"px-6 py-4\">${carpet.size}</td> <td class=\"px-6 py-4 text-stone-500\">$${carpet.cost}</td> <td class=\"px-6 py-4 font-bold text-stone-800\">$${carpet.price}</td> <td class=\"px-6 py-4\"> <span class=\"px-2.5 py-1 rounded-full text-xs font-bold ${carpet.stock <= 3 ? 'bg-red-100 text-red-800' : 'bg-emerald-100 text-emerald-800'}\"> ${carpet.stock} دانە </span> </td> <td class=\"px-6 py-4 text-center\"> <button onclick=\"deleteCarpet('${carpet.id}')\" class=\"text-red-600 hover:text-red-950 transition-colors\"><i class=\"fa-regular fa-trash-can\"></i> سڕینەوە</button> </td> `; tbody.appendChild(tr); }); } function openAddCarpetModal() { document.getElementById('add-carpet-modal').classList.remove('hidden'); } function closeAddCarpetModal() { document.getElementById('add-carpet-modal').classList.add('hidden'); document.getElementById('add-carpet-form').reset(); } function saveCarpet(e) { e.preventDefault(); const name = document.getElementById('carpet-name').value; const origin = document.getElementById('carpet-origin').value; const size = document.getElementById('carpet-size').value; const stock = parseInt(document.getElementById('carpet-stock').value); const cost = parseFloat(document.getElementById('carpet-cost').value); const price = parseFloat(document.getElementById('carpet-price').value); const id = 'CRP-' + (100 + carpets.length + 1); carpets.push({ id, name, origin, size, cost, price, stock }); renderCarpets(); populateCarpetSelect(); updateDashboardWidgets(); closeAddCarpetModal(); } function deleteCarpet(id) { if(confirm('ئایا دڵنیایت لە سڕینەوەی ئەم فەرشە لە کۆگا؟')) { carpets = carpets.filter(c => c.id !== id); renderCarpets(); populateCarpetSelect(); updateDashboardWidgets(); } } function renderInvoices() { const tbody = document.getElementById('invoice-table-body'); tbody.innerHTML = ''; invoices.forEach(inv => { const tr = document.createElement('tr'); tr.className = 'hover:bg-stone-50 transition divide-x divide-x-reverse divide-stone-100'; tr.innerHTML = ` <td class=\"px-6 py-4 font-bold text-emerald-800\">${inv.id}</td> <td class=\"px-6 py-4 font-semibold\">${inv.customer}</td> <td class=\"px-6 py-4\">${inv.date}</td> <td class=\"px-6 py-4\">${inv.carpetName}</td> <td class=\"px-6 py-4\">${inv.qty} دانە</td> <td class=\"px-6 py-4 font-bold text-stone-900\">$${inv.total}</td> <td class=\"px-6 py-4 text-center\"> <button onclick=\"viewInvoice('${inv.id}')\" class=\"bg-stone-100 hover:bg-stone-200 text-stone-800 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors\"><i class=\"fa-regular fa-eye ml-1\"></i> پیشاندان</button> </td> `; tbody.appendChild(tr); }); } function populateCarpetSelect() { const select = document.getElementById('invoice-carpet-select'); select.innerHTML = ''; carpets.forEach(carpet => { if (carpet.stock > 0) { const option = document.createElement('option'); option.value = carpet.id; option.innerText = `${carpet.name} (${carpet.origin}) - نرخ: $${carpet.price} - ماوە لە کۆگا: ${carpet.stock} دانە`; select.appendChild(option); } }); updateInvoicePricing(); } function updateInvoicePricing() { const select = document.getElementById('invoice-carpet-select'); if(!select.value) return; const carpet = carpets.find(c => c.id === select.value); const qty = parseInt(document.getElementById('invoice-qty').value) || 1; const discount = parseFloat(document.getElementById('invoice-discount').value) || 0; document.getElementById('invoice-single-price').innerText = '$' + carpet.price; const total = (carpet.price * qty) - discount; document.getElementById('invoice-total-display').innerText = '$' + total.toLocaleString(); document.getElementById('invoice-cost-display').innerText = '$' + (carpet.cost * qty).toLocaleString(); } function openNewInvoiceModal() { populateCarpetSelect(); document.getElementById('invoice-modal').classList.remove('hidden'); } function closeNewInvoiceModal() { document.getElementById('invoice-modal').classList.add('hidden'); document.getElementById('invoice-form').reset(); } function saveInvoice(e) { e.preventDefault(); const customer = document.getElementById('customer-name').value; const phone = document.getElementById('customer-phone').value; const carpetId = document.getElementById('invoice-carpet-select').value; const qty = parseInt(document.getElementById('invoice-qty').value); const discount = parseFloat(document.getElementById('invoice-discount').value) || 0; const carpet = carpets.find(c => c.id === carpetId); if (carpet.stock < qty) { alert('ببوورە! تەنها ' + carpet.stock + ' دانە لەم فەرشە لە کۆگادا ماوە.'); return; } carpet.stock -= qty; const total = (carpet.price * qty) - discount; const id = 'INV-' + (5000 + invoices.length + 1); const today = new Date().toISOString().split('T')[0]; invoices.push({ id, customer, phone, date: today, carpetId, carpetName: `${carpet.name} (${carpet.origin})`, qty, price: carpet.price, discount, total, cost: carpet.cost }); renderCarpets(); renderInvoices(); updateDashboardWidgets(); renderFinances(); closeNewInvoiceModal(); } function viewInvoice(id) { const inv = invoices.find(i => i.id === id); if(!inv) return; document.getElementById('view-inv-id').innerText = inv.id; document.getElementById('view-inv-date').innerText = inv.date; document.getElementById('view-inv-customer').innerText = inv.customer; document.getElementById('view-inv-phone').innerText = inv.phone; document.getElementById('view-inv-carpet-title').innerText = inv.carpetName; document.getElementById('view-inv-qty').innerText = inv.qty; document.getElementById('view-inv-price').innerText = '$' + inv.price; document.getElementById('view-inv-subtotal').innerText = '$' + (inv.price * inv.qty); document.getElementById('view-inv-discount').innerText = '$' + inv.discount; document.getElementById('view-inv-total').innerText = '$' + inv.total; document.getElementById('invoice-view-modal').classList.remove('hidden'); } function closeInvoiceViewModal() { document.getElementById('invoice-view-modal').classList.add('hidden'); } function renderFinances() { let totalRevenue = invoices.reduce((acc, curr) => acc + curr.total, 0); let totalCost = invoices.reduce((acc, curr) => acc + (curr.cost * curr.qty), 0); let netProfit = totalRevenue - totalCost; document.getElementById('finance-total-revenue').innerText = '$' + totalRevenue.toLocaleString(); document.getElementById('finance-total-cost').innerText = '$' + totalCost.toLocaleString(); document.getElementById('finance-net-profit').innerText = '$' + netProfit.toLocaleString(); const tbody = document.getElementById('finance-table-body'); tbody.innerHTML = ''; invoices.forEach(inv => { const profit = inv.total - (inv.cost * inv.qty); const tr = document.createElement('tr'); tr.className = 'hover:bg-stone-50 transition divide-x divide-x-reverse divide-stone-100'; tr.innerHTML = ` <td class=\"px-6 py-4 text-stone-500\">${inv.date}</td> <td class=\"px-6 py-4\"><span class=\"bg-emerald-100 text-emerald-800 text-xs font-bold px-2 py-1 rounded\">فرۆشتن</span></td> <td class=\"px-6 py-4 font-medium\">فاتورەی ژمارە ${inv.id} (کڕیار: ${inv.customer})</td> <td class=\"px-6 py-4 font-bold text-emerald-600\">+$${inv.total}</td> <td class=\"px-6 py-4 text-stone-500\"><span class=\"text-xs text-stone-400\">قازانج: +$${profit}</span></td> `; tbody.appendChild(tr); }); carpets.forEach(c => { const tr = document.createElement('tr'); tr.className = 'hover:bg-stone-50 transition divide-x divide-x-reverse divide-stone-100'; tr.innerHTML = ` <td class=\"px-6 py-4 text-stone-500\">-</td> <td class=\"px-6 py-4\"><span class=\"bg-amber-100 text-amber-800 text-xs font-bold px-2 py-1 rounded\">تێچووی کۆگا</span></td> <td class=\"px-6 py-4 font-medium\">فەرشی ${c.name} لە کۆگادا (${c.stock} دانە)</td> <td class=\"px-6 py-4 text-red-600\">-$${c.cost * c.stock}</td> <td class=\"px-6 py-4 text-stone-500\"><span class=\"text-xs text-stone-400\">سەرمایەی خەوێندراو</span></td> `; tbody.appendChild(tr); }); } function initChart() { const ctx = document.getElementById('revenueChart').getContext('2d'); if(chartInstance) { chartInstance.destroy(); } let salesData = {}; invoices.forEach(inv => { const date = inv.date; salesData[date] = (salesData[date] || 0) + inv.total; }); const sortedDates = Object.keys(salesData).sort(); const dataset = sortedDates.map(date => salesData[date]); chartInstance = new Chart(ctx, { type: 'line', data: { labels: sortedDates.length > 0 ? sortedDates : ['2025-02-10', '2025-02-15', '2025-02-18'], datasets: [{ label: 'کۆی فرۆشی ڕۆژانە ($)', data: dataset.length > 0 ? dataset : [1200, 2500, 3300], borderColor: '#8B0000', backgroundColor: 'rgba(139, 0, 0, 0.1)', fill: true, tension: 0.3, borderWidth: 3 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#f3f4f6' } }, x: { grid: { display: false } } } } }); } window.onload = initApp;</script></body></html>",
